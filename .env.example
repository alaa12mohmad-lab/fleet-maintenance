# ═══════════════════════════════════════════════════════════════
# Fleet Maintenance System - Environment Variables
# ═══════════════════════════════════════════════════════════════
#
# 1. Copy this file to .env
#    cp .env.example .env
#
# 2. Fill in your Firebase project values
#    (Firebase Console → Project Settings → Your apps → Web app)
#
# 3. NEVER commit .env to git (already in .gitignore)
# ═══════════════════════════════════════════════════════════════

VITE_FIREBASE_API_KEY=AIzaSy_your_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abc123def456

# Admin email (must match the account created in Firebase Auth)
VITE_ADMIN_EMAIL=alaa12mohmad@gmail.com
